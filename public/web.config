Import-Module WebAdministration

New-Item -ItemType Directory -Path "C:\inetpub\gis-dashboard" -Force

New-WebAppPool -Name "GISDashboardPool"
Set-ItemProperty "IIS:\AppPools\GISDashboardPool" -Name managedRuntimeVersion -Value ""   # no .NET runtime needed, it's a static SPA

New-Website -Name "GISDashboard" -Port 80 -PhysicalPath "C:\inetpub\gis-dashboard" -ApplicationPool "GISDashboardPool"